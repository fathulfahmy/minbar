{
  "$schema": "https://github.com/glzr-io/zebar/raw/v3.0.0/resources/zpack-schema.json",
  "name": "minbar",
  "version": "1.0.0",
  "description": "Minimal Zebar with GlazeWM widget pack based on glzer-io.starter.",
  "tags": ["topbar"],
  "previewImages": ["resources\\preview.png"],
  "repositoryUrl": "",
  "widgets": [
    {
      "name": "default",
      "htmlPath": "./default.html",
      "zOrder": "top_most",
      "shownInTaskbar": false,
      "focused": false,
      "resizable": false,
      "transparent": false,
      "includeFiles": ["*.html", "*.css"],
      "caching": {
        "defaultDuration": 604800,
        "rules": []
      },
      "privileges": {
        "shellCommands": []
      },
      "presets": [
        {
          "name": "default",
          "anchor": "top_left",
          "offsetX": "0px",
          "offsetY": "0px",
          "width": "100%",
          "height": "20px",
          "monitorSelection": {
            "type": "all"
          },
          "dockToEdge": {
            "enabled": true,
            "edge": null,
            "windowMargin": "0px"
          }
        }
      ]
    }
  ]
}
